/*
 * coron.keymap — Migrated from CornixLP (Vial) to CoronLP (ZMK)
 *
 * Layer Map:
 *   0: Base (QWERTY)
 *   1: NUM/SYM  (was CornixLP layer 1)
 *   2: SYM/NUM  (was CornixLP layer 2)
 *   3: FN       (was CornixLP layer 4)
 *   4: MOUSE    (AML - automouse-layer, trackball trigger)
 *   5: SCROLL   (scroll-layer for trackball)
 *   6: NAV      (was CornixLP layer 5 - arrows/nav)
 *   7: SYSTEM   (BT controls + merged from CornixLP layer 9)
 *
 * Tap Dance → Hold-Tap Migration:
 *   TD(1) → td1: tap=sl(1)   hold=mo(1)   [dtap Ctrl+Enter dropped]
 *   TD(2) → td2: tap=sl(2)   hold=mo(2)
 *   TD(4) → td4: tap=MHEN    hold=mo(3)   [dtap Alt+Space dropped]
 *   TD(5) → td5: tap=HENK    hold=mo(6)   [dtap Alt+Space dropped]
 *
 * Combo Key Position Reference (CoronLP):
 *   Row 0: 0=TAB  1=Q  2=W  3=E  4=R  5=T  |  6=Y  7=U   8=I    9=O  10=P  11=BSPC
 *   Row 1: 12=CAP 13=A 14=S 15=D 16=F 17=G  18=scr 19=scr 20=H  21=J  22=K  23=L  24='  25=ENT
 *   Row 2: 26=LSF 27=Z 28=X 29=C 30=V 31=B  32=scr 33=scr 34=N  35=M  36=,  37=.  38=/  39=RSF
 *   Row 3: 40=LCT 41=GUI 42=ALT 43=ALT 44=HENK 45=SPC 46=MUHEN 47=SPC 48=ENT 49=DEL 50=_
 */

#include <behaviors.dtsi>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/pointing.h>

// OS設定を日本語キーボードのまま使用するための変換定義
#define JP_DQUOTE       AT                // "
#define JP_AMPERSAND    CARET             // &
#define JP_QUOTE        AMPERSAND         // '
#define JP_EQUAL        UNDER             // =
#define JP_CARET        EQUAL             // ^
#define JP_YEN          0x89              // ¥
#define JP_PLUS         COLON             // +
#define JP_TILDE        PLUS              // ~
#define JP_PIPE         LS(0x89)          // |
#define JP_AT           LEFT_BRACKET      // @
#define JP_COLON        SINGLE_QUOTE      // :
#define JP_ASTERISK     DOUBLE_QUOTES     // *
#define JP_BACKQUOTE    LEFT_BRACE        // `
#define JP_UNDERSCORE   LS(0x87)          // _
#define JP_LBRACKET     RIGHT_BRACKET     // [
#define JP_RBRACKET     BACKSLASH         // ]
#define JP_LPAREN       ASTERISK          // (
#define JP_RPAREN       LEFT_PARENTHESIS  // )
#define JP_LBRACE       RIGHT_BRACE       // {
#define JP_RBRACE       PIPE              // }
#define JP_KANA         LANGUAGE_1        // かな
#define JP_EISU         LANGUAGE_2        // 英数
#define JP_HANZEN       GRAVE             // 半角/全角

/* ── Global behavior tuning ─────────────────────────────────── */

&mt {
    flavor = "balanced";
    quick-tap-ms = <0>;
};

&trackball {
    automouse-layer = <4>;
    scroll-layers = <5>;
};

/ {
    /* ── Combos ─────────────────────────────────────────────────── */
    /*  Migrated from CornixLP Vial combos.                        */
    /*  All output F-keys are AHK triggers — adjust positions if    */
    /*  you rearrange the base layer.                               */

    combos {
        compatible = "zmk,combos";

        /* Q + TAB → ESC */

        combo_esc {
            bindings = <&kp ESC>;
            key-positions = <1 0>;
        };

        /* D + S → F14 */

        combo_f14 {
            bindings = <&kp F14>;
            key-positions = <15 14>;
        };

        /* D + F → F13 */
        /* F + G → MINUS (direct key, not AHK) */
        /* J + K → F15 */
        /* K + L → F16 */
        /* V + C → F18 */
        /* M + COMMA → F19 */
        /* R + T → F20 */
        /*
         * CornixLP combo: RCTRL+UP → RSHIFT
         * No base-layer arrow/RCTRL on CoronLP. Dropped.
         * Alternative: DOT+SLASH (pos 37+38) → RSHIFT
         *
         * combo_rshift {
         *     bindings = <&kp RSHIFT>;
         *     key-positions = <37 38>;
         * };
         */
    };

    /* ── Macros ─────────────────────────────────────────────────── */

    macros {
        /* M0: Alt+Space (was double-tap of TD4/TD5) */

        m_alt_space: m_alt_space {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings =
                <&macro_press>,
                <&kp LALT>,
                <&macro_tap>,
                <&kp SPACE>,
                <&macro_release>,
                <&kp LALT>;

            label = "MACRO_ALT_SPACE";
        };

        /* M1: Ctrl+Enter (was double-tap of TD1) */
        /* Helper: tap key then go to layer 0 (from CoronLP default) */
    };

    /* ── Behaviors (Hold-Tap replacements for Tap Dance) ────────── */

    behaviors {
        /* TD(1): tap → sl(1), hold → mo(1) */

        td1: td1_hold_tap {
            compatible = "zmk,behavior-hold-tap";
            label = "TD1_SL1_MO1";
            #binding-cells = <2>;
            bindings = <&mo>, <&sl>;

            tapping-term-ms = <250>;
            flavor = "balanced";
        };

        /* TD(2): tap → sl(2), hold → mo(2) */
        /* TD(4): tap → MHEN, hold → mo(3=FN) */
        /* TD(5): tap → HENK, hold → mo(6=NAV) */
        /* Layer-tap-to-0 (for system layer access) */
    };

    /* ── Keymap ─────────────────────────────────────────────────── */

    keymap {
        compatible = "zmk,keymap";

        /* ── Layer 0: Base (QWERTY) ─────────────────────────────
         *
         * Differences from CornixLP:
         *  - Arrow keys removed from base → use NAV layer (hold TD5)
         *  - SQT and SLASH gain dedicated keys on right pinky column
         *  - LBRACKET ([) moved to right thumb area (pos 50)
         *  - Inner scroll columns for trackball (pos 18,19,32,33)
         *  - Left thumb: td1(sl1/mo1) → td4(MHEN/mo3) → SPC
         *  - Right thumb: SPC → td5(HENK/mo6) → td2(sl2/mo2)
         *  - System layer via lt_to_layer_0 on inner thumb
         */

        default_layer {
            bindings = <
&kp TAB         &kp Q         &kp W         &kp E          &kp R                        &kp T        &kp Y                          &kp U              &lt 5 I      &kp O     &kp P      &kp BACKSPACE
&kp CAPSLOCK    &kp A         &kp S         &kp D          &kp F                        &kp G        &kp K_SCROLL_UP                &kp K_SCROLL_UP    &kp H        &kp J     &kp K      &kp L          &kp JP_AT    &kp ENTER
&kp LEFT_SHIFT  &kp Z         &kp X         &kp C          &kp V                        &kp B        &kp K_SCROLL_DOWN              &kp K_SCROLL_DOWN  &kp N        &kp M     &kp COMMA  &kp DOT        &kp SLASH  &kp RCTRL
&kp LCTRL       &kp LEFT_WIN  &kp LEFT_ALT  &kp LA(SPACE)  &lt_to_layer_0 6 INT_HENKAN  &lt 2 SPACE  &lt_to_layer_0 3 INT_MUHENKAN  &kp SPACE          &lt 2 ENTER  &kp LEFT  &kp RIGHT
            >;
        };

        /* ── Layer 1: NUM/SYM (was CornixLP layer 1) ───────────
         *
         * Left: ESC, numbers 1-5, Alt+1..4
         * Right: numbers 6-0, DEL, symbols (;='- etc), JIS keys
         */

        NUMBER {
            bindings = <
&trans  &kp NUMBER_1  &kp NUMBER_2  &kp NUMBER_3  &kp NUMBER_4  &kp N5  &kp NUMBER_6  &kp N7  &kp N8         &kp N9   &kp N0  &kp DEL
&trans  &trans        &trans        &trans        &trans        &trans  &trans        &trans  &kp SEMICOLON  &kp F7   &kp F8  &kp F9   &kp F10  &trans
&trans  &trans        &trans        &trans        &trans        &trans  &trans        &trans  &trans         &trans   &trans  &trans   &kp F11  &trans
&trans  &trans        &trans        &trans        &trans        &trans  &trans        &trans  &trans         &kp F12  &trans
            >;
        };

        /* ── Layer 2: SYM/NUM (was CornixLP layer 2) ───────────
         *
         * Left: shifted symbols !@#$%, ;'- on home, 1-5 on bottom
         * Right: shifted symbols ^&*(), brackets, F21
         */

        SYM_NUM {
            bindings = <
&kp ESC  &kp LS(N1)  &kp LS(N2)  &kp LS(N3)  &kp LS(N4)  &kp LS(N5)  &kp LS(N6)  &kp LS(N7)  &kp LS(N8)  &kp LS(N9)  &kp LS(MINUS)    &kp DEL
&none    &none       &none       &kp SEMI    &kp SQT     &kp MINUS   &trans      &trans      &none       &kp RBKT    &kp NON_US_HASH  &none    &kp F21  &kp ENTER
&none    &kp N1      &kp N2      &kp N3      &kp N4      &kp N5      &trans      &trans      &kp N6      &kp N7      &kp N8           &kp N9   &kp N0   &kp RSHIFT
&none    &none       &none       &none       &none       &none       &trans      &none       &none       &none       &kp RCTRL
            >;
        };

        /* ── Layer 3: FN (was CornixLP layer 4) ────────────────
         *
         * F1-F12, brackets, PgUp/PgDn
         */

        FN {
            bindings = <
&kp ESC  &kp F1  &kp F2  &kp F3  &kp F4    &kp F5     &kp F6  &kp F7     &kp F8  &kp F9     &kp F10   &kp F11
&none    &none   &none   &none   &kp SEMI  &kp MINUS  &trans  &trans     &none   &none      &kp RBKT  &kp NON_US_HASH  &kp F11  &kp F12
&none    &none   &none   &none   &none     &none      &trans  &trans     &none   &none      &none     &kp PG_UP        &none    &none
&none    &none   &none   &none   &none     &kp ENTER  &trans  &kp ENTER  &none   &kp PG_DN  &none
            >;
        };

        /* ── Layer 4: MOUSE (AML - automouse-layer) ────────────
         *
         * Triggered automatically by trackball movement.
         *   H (pos 20) = MB4 (Back)
         *   J (pos 21) = MB1 (Left click)
         *   K (pos 22) = MB3 (Middle click)
         *   L (pos 23) = MB2 (Right click)
         *   ' (pos 24) = MB5 (Forward)
         */

        MOUSE {
            bindings = <
&trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans    &trans    &trans    &trans
&trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans  &mkp MB4  &mkp MB1  &mkp MB3  &mkp MB2  &mkp MB5  &trans
&trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans    &trans    &trans    &trans    &trans    &trans
&trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans    &trans    &trans
            >;
        };

        /* ── Layer 5: SCROLL (scroll-layer for trackball) ──────
         *
         * All transparent — trackball hardware handles scroll.
         */

        SCROLL {
            bindings = <
&trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans
&trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans
&trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans
&trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans  &trans
            >;
        };

        /* ── Layer 6: NAV (was CornixLP layer 5) ───────────────
         *
         * Arrow keys in vim-style HJKL on right home row.
         * PgUp/PgDn on right pinky column.
         * F-keys on top row (same as CornixLP layer 5).
         */

        NAV {
            bindings = <
&kp ESC     &kp F1  &kp F2  &kp F3  &kp F4  &kp F5  &kp F6  &kp F7  &kp F8    &kp F9    &kp F10  &kp F11
&none       &none   &none   &none   &none   &none   &trans  &trans  &kp LEFT  &kp DOWN  &kp UP   &kp RIGHT  &kp PG_UP  &kp F12
&kp LSHIFT  &none   &none   &none   &none   &none   &trans  &trans  &none     &none     &none    &none      &kp PG_DN  &kp RSHIFT
&kp LCTRL   &none   &none   &none   &none   &none   &trans  &none   &none     &none     &none
            >;
        };

        /* ── Layer 7: SYSTEM (BT + macros) ─────────────────────
         *
         * BT select/clear, bootloader.
         * Alt+Space / Ctrl+Enter macros on left home/bottom row
         * (since double-tap is lost in ZMK migration).
         */
    };
};
